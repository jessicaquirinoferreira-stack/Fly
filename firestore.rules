rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email.lower() == 'jessicaquirinoferreira@gmail.com'.lower()) ||
        (request.auth.token.email.lower() == 'fly@store.com'.lower())
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Products
    match /products/{productId} {
      allow get: if isValidId(productId) && (isAdmin() || existing().active == true);
      allow list: if isAdmin() || resource.data.active == true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'imageUrl', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.imageUrl is string && data.imageUrl.size() > 0 &&
             data.createdAt is timestamp &&
             (data.get('brand', '') is string) &&
             (data.get('category', '') is string) &&
             (data.get('active', true) is bool) &&
             (data.get('featured', false) is bool) &&
             (data.get('sizes', []) is list);
    }

    // Settings
    match /settings/global {
      allow read: if true; // Publicly readable for store info
      allow write: if isAdmin() && isValidSettings(incoming());
    }

    function isValidSettings(data) {
      return data.whatsappNumber is string && data.whatsappNumber.size() <= 20 &&
             data.storeName is string &&
             (data.get('email', '') is string) &&
             (data.get('instagramUrl', '') is string) &&
             (data.get('facebookUrl', '') is string);
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if isValidOrder(incoming());
      allow update, delete: if isAdmin();
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerPhone', 'address', 'items', 'total', 'createdAt', 'status']) &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.customerPhone is string && data.customerPhone.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    // Admins collection - used for RBAC
    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isSignedIn() && (
        request.auth.uid == adminId && (
          (request.auth.token.email.lower() == 'jessicaquirinoferreira@gmail.com'.lower()) ||
          (request.auth.token.email.lower() == 'fly@store.com'.lower())
        )
      );
    }
  }
}
